      <aliases enabled='yes' />
      <column caption='Avg Transaction Value' datatype='real' name='[Calculation_3818559953485488128]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Total]) / COUNTD([Invoice ID])' />
      </column>
      <column caption='Total Transactions' datatype='integer' name='[Calculation_3818559953485836290]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Invoice ID])' />
      </column>
      <column caption='Profit' datatype='real' name='[Calculation_4264064472890257409]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Total]-[Unit price]' />
      </column>
      <column caption='Profit Margin' datatype='real' name='[Calculation_4264064472890445826]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[gross income] / [Total] * 100' />
      </column>
      <column caption='Growth Rate Calculation' datatype='real' name='[Calculation_4264064472891486211]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(IF LOOKUP(SUM([Total]), -1) != 0 &#10;THEN (SUM([Total]) - LOOKUP(SUM([Total]), -1)) / LOOKUP(SUM([Total]), -1) &#10;ELSE NULL &#10;END) * 100'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Max Weekly Growth' datatype='real' name='[Calculation_4264064472892190724]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_MAX(&#10;    (SUM([Total]) - LOOKUP(SUM([Total]), -1)) / LOOKUP(SUM([Total]), -1) * 100&#10;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Min Weekly Growth' datatype='real' name='[Calculation_4264064472892661765]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_MIN(&#10;    (SUM([Total]) - LOOKUP(SUM([Total]), -1)) / LOOKUP(SUM([Total]), -1) * 100&#10;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Avg Profit Margin' datatype='real' name='[Calculation_4264064472892788742]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([gross income] / [Total]) * 100' />
      </column>
